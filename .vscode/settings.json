{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python",
  "python.terminal.activateEnvironment": true,
  "editor.rulers": [],

  "cSpell.enabled": true,             // Erweiterung für das Projekt aktivieren
  "cSpell.language": "de",            // Deutsch als primäre Prüfsprache
  "cSpell.allowCompoundWords": true,  // Erlaubt deutsche Komposita
  "cSpell.languageSettings": [
    {
      "languageId": "python",         // Rechtschreibprüfung in Python, für
      "includeRegExpList": [
        "comments",                   // Kommentare
        "strings"                     // Docstrings und String-Literalen
      ]
    }
  ],
  "cSpell.words": [
    "align",
    "Clusterstrukturen",
    "dateiformatübergreifende",
    "datenzentrierte",
    "Emmy",
    "Exponentialdarstellung",
    "extremal",
    "German",
    "gezoomt",
    "High",
    "Lagrange",
    "Matplotlib",
    "Noether",
    "Noethers",
    "Numpy",
    "plotly",
    "Publikationsgrafiken",
    "Ready",
    "Scatterplot",
    "Spell",
    "Stationarität",
    "Visual"
  ],
}